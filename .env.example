# Optional API keys (Scrapling is default; APIs are fallbacks)
WEATHER_API_KEY=
NEWS_API_KEY=
ODDS_API_KEY=

# Reddit intel (optional — defaults to neutral when unset)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Trismegistus/0.3

# OddsPortal scrape cache TTL (hours); avoids re-scraping on every fetch_odds call
ODDS_CACHE_TTL_HOURS=6

# Bookie blend weight override (default read from config/leagues.yaml model.bookie_blend_weight)
BOOKIE_BLEND_WEIGHT=

# Min edge vs bookie implied to emit a pick (default from leagues.yaml model.edge_margin_min)
EDGE_MARGIN_MIN=

# Scrapling (Phase 2) — stealth scraping for odds, news, injuries
TRIS_USE_SCRAPLING=true
TRIS_SCRAPE_STEALTH=true
TRIS_SCRAPE_HEADLESS=true
# Auto-scrape OddsPortal on cache miss during --predict (default: run --fetch-odds first)
TRIS_AUTO_SCRAPE_ODDS=false