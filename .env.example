# Optional API keys (Scrapling is default; APIs are fallbacks)
WEATHER_API_KEY=
NEWS_API_KEY=
ODDS_API_KEY=

# OddsPortal scrape cache TTL (hours); avoids re-scraping on every fetch_odds call
ODDS_CACHE_TTL_HOURS=6

# Bookie blend weight override (default read from config/leagues.yaml model.bookie_blend_weight)
BOOKIE_BLEND_WEIGHT=

# Scrapling (Phase 2) — stealth scraping for odds, news, injuries
TRIS_USE_SCRAPLING=true
TRIS_SCRAPE_STEALTH=true
TRIS_SCRAPE_HEADLESS=true